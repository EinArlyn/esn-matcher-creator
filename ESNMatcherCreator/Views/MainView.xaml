<Window x:Class="ESNMatcherCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewmodel="clr-namespace:ESNMatcherCreator.ViewModels"
        mc:Ignorable="d"
        Title="ESNMatcher Creator" Height="450" Width="800"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{x:Null}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True">
    <Window.DataContext>
        <viewmodel:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <materialDesign:Card
            Background="#252525"
            materialDesign:ElevationAssist.Elevation="Dp4"
            Margin="10"
            UniformCornerRadius="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="5*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        Orientation="Horizontal">
                        <Button
                            Margin="15 0 0 0"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Загрузить из CSV файла"
                            Click="FileDelimited_Click">
                            <materialDesign:PackIcon
                                Kind="FileDelimited" />
                        </Button>
                        <Button
                            Margin="15 0 0 0"
                            IsEnabled="{Binding IsFormatButtonEnabled}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Обработать данные"
                            Command="{Binding FormatClick}"
                            CommandParameter="{Binding MatcherDataList}">
                            <materialDesign:PackIcon
                                Kind="FormatColumns" />
                        </Button>
                        <Button
                            Margin="15 0 0 0"
                            IsEnabled="{Binding IsCopyButtonEnabled}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Скопировать в буфер"
                            Command="{Binding CopyClick}"
                            CommandParameter="{Binding FormattedData}">
                            <materialDesign:PackIcon
                                Kind="ContentCopy" />
                        </Button>
                        <Button
                            Margin="15 0 0 0"
                            IsEnabled="{Binding IsSaveButtonEnabled}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Сохранить в файл"
                            Click="FileSave_Click">
                            <materialDesign:PackIcon
                                Kind="ContentSave" />
                        </Button>
                    </StackPanel>
                    <TextBlock
                        Grid.Column="1"
                        Text="ESN Matcher Creator"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        FontSize="36"
                        FontStretch="Medium"
                        FontWeight="Medium"
                        Foreground="#46306E"
                        FontFamily="{DynamicResource MaterialDesignFont}"/>
                    <Button
                        Grid.Column="2"
                        Margin="0 0 15 0"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Выход из приложения"
                        Command="{Binding ExitToAppClick}">
                        <materialDesign:PackIcon
                            Kind="ExitToApp" />
                    </Button>
                </Grid>
                <Grid
                    Grid.Row="1">
                    <materialDesign:Card
                        materialDesign:ElevationAssist.Elevation="Dp3"
                        UniformCornerRadius="15"
                        Background="#E4E4E4">
                        <Grid>
                            <ListView
                                Margin="10"
                                Foreground="#252525"
                                ItemsSource="{Binding MatcherDataList}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn
                                            DisplayMemberBinding="{Binding Type}"
                                            Header="Type" />
                                        <GridViewColumn
                                            DisplayMemberBinding="{Binding Ticker}"
                                            Header="Ticker" />
                                        <GridViewColumn
                                            DisplayMemberBinding="{Binding TickerId}"
                                            Header="Ticker ID" />
                                        <GridViewColumn
                                            DisplayMemberBinding="{Binding LP}"
                                            Header="LP" />
                                        <GridViewColumn
                                            DisplayMemberBinding="{Binding LpId}"
                                            Header="LP ID" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <!-- long hand form for setting the message -->
                            <materialDesign:Snackbar
                                Margin="0 10"
                                IsActive="{Binding IsActiveSnackBar}">
                                <materialDesign:SnackbarMessage
                                    ActionContent="ЗАКРЫТЬ"
                                    ActionCommand="{Binding SnackbarCloseClick}"
                                    Content="{Binding ContentSnackBar}" />
                            </materialDesign:Snackbar>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>
